    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "openai": "^4.80.0",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "concurrently": "^8.2.2",
    "vite": "^5.4.0"
  }
}