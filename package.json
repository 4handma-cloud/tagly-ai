{
  "name": "tagly-ai",
  "version": "1.0.0",
  "private": true,
  "description": "Tagly AI – Real-time Hashtag Intelligence for Creators",
  "type": "module",
  "scripts": {
    "start": "node server/server.js",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
