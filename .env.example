# Tagly AI Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3001

# OpenAI API Key (optional - enables AI scoring + Image-to-Tag)
OPENAI_API_KEY=

# Redis URL (optional - uses in-memory cache by default)
REDIS_URL=

# API Keys for live data (optional - uses simulated data by default)
YOUTUBE_API_KEY=
TIKTOK_API_KEY=
X_BEARER_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
PINTEREST_API_KEY=
LINKEDIN_ACCESS_TOKEN=
